# Variables de entorno de la Vercel Function. Copia a Vercel (Project Settings →
# Environment Variables). Los valores reales NO van aquí: viven en vercel.env.local
# (gitignored) y en el dashboard de Vercel.

# URL /exec del Apps Script Web App.
SHEETS_WEBHOOK_URL=

# Token compartido (idéntico al var TOKEN del Apps Script).
SHEETS_TOKEN=

# Origen(es) donde se renderiza la landing (scheme + host, sin ruta). Coma para varios.
ALLOWED_ORIGINS=https://atomchat.io
