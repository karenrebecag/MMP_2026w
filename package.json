{
  "name": "mmp-2026w",
  "version": "1.0.0",
  "description": "Landing page versionada para ATOM Academy. Lógica + estilos servidos vía jsDelivr; Elementor solo aporta un punto de montaje.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "dev": "node esbuild.config.mjs --serve",
    "typecheck": "tsc --noEmit",
    "css:audit": "node scripts/css-audit.mjs",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "semi": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "arrowParens": "always"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "lenis": "^1.3.23"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
